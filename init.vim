syntax on
set notermguicolors
" set number relativenumber
set tabstop=4
set shiftwidth=4
set autoindent
set expandtab
set ruler
set list
set lcs=tab:>-,space:·,trail:~,extends:>,precedes:<,nbsp:␣
set ignorecase smartcase
set clipboard+=unnamedplus
cnoreabbrev t term
cnoreabbrev ex Ex
colorscheme vim
set noswapfile
set guicursor=a:ver1
nn j jzz
nn k kzz
set mousescroll=ver:1,hor:1
set splitright
