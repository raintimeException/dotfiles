syntax on
set tabstop=4
set shiftwidth=4
set autoindent
set expandtab
set ruler
set list
set lcs=tab:>-,space:·,trail:~,extends:>,precedes:<,nbsp:␣
set ignorecase smartcase
set clipboard+=unnamed
cnoreabbrev t term
cnoreabbrev ex Ex
set noswapfile
set guicursor=a:ver1
nn j jzz
nn k kzz
set splitright
set number
colorscheme koehler
